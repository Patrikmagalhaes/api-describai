generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Generation {
  id          String   @id @default(cuid())

  imageUrl    String
  altText     String

  language    String
  tone        String
  size        String

  createdAt   DateTime @default(now())
}